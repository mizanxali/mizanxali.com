const techMeta = {
  "TypeScript": { slug: "typescript" },
  React: { slug: "react" },
  "Next.js": { slug: "nextdotjs", color: "white" },
  "Tailwind": { slug: "tailwindcss" },
  "Node.js": { slug: "nodedotjs" },
  "React Native": { slug: "react" },
  Solidity: { slug: "solidity", color: "white" },
  Postgres: { slug: "postgresql" },
  GraphQL: { slug: "graphql" },
  Wagmi: { slug: "wagmi",  color: "white" },
  Stripe: { slug: "stripe" },
  Firebase: { slug: "firebase" },
  Polygon: { slug: "polygon" },
  SQLite: { slug: "sqlite" },
