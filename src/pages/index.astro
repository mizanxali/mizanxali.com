const skills = [
  "TypeScript",
  "React",
  "Next.js",
  "React Native",
  "Node.js",
  "WebRTC",
  "Solidity",
  "Ethers.js",
  "Wagmi",
  "Tailwind CSS",
  "PostgreSQL",
  "GraphQL",
  "Docker",
  "AWS",
];

const techMeta = {
  "TypeScript": { slug: "typescript" },
  React: { slug: "react" },
  "Next.js": { slug: "nextdotjs", color: "white" },
  "Tailwind CSS": { slug: "tailwindcss" },
  "Node.js": { slug: "nodedotjs" },
  "React Native": { slug: "react" },
  Solidity: { slug: "solidity", color: "white" },
  PostgreSQL: { slug: "postgresql" },
  GraphQL: { slug: "graphql" },
  Wagmi: { fallback: "Wg" },
  Stripe: { slug: "stripe", fallback: "St" },
  Firebase: { slug: "firebase", fallback: "Fb" },
  Polygon: { slug: "polygon", fallback: "Po" },
  SQLite: { slug: "sqlite", fallback: "Sq" },
  ONNX: { slug: "onnx", fallback: "Ox" },
  tRPC: { slug: "trpc", fallback: "tR" },
  Hono: { slug: "hono", fallback: "Ho" },
  Zustand: { fallback: "Zu" },
  Partykit: { fallback: "Pk" },
  RetinaFace: { fallback: "Rf" },
  OpenAI: { slug: "openai", color: "white" },
  Electron: { slug: "electron" },
  OpenCV: { slug: "opencv" },
  Arbitrum: { slug: "arbitrum" },
  Python: { slug: "python" },
  FFmpeg: { slug: "ffmpeg" },
  YouTube: { slug: "youtube" },
  "Socket.IO": { slug: "socketdotio", color: "white" },
  Android: { slug: "android" },
  Farcaster: { slug: "farcaster" },
  Base: { slug: "base" },
  Uniswap: { slug: "uniswap" },
  Ethereum: { slug: "ethereum" },
  "Google Maps": { slug: "googlemaps" },
  WebRTC: { custom: "webrtc" },
};
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mizan Ali</title>
    <meta
      name="description"
      content="Fullstack product engineer building at the intersection of complex frontend engineering and onchain realtime systems."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-neutral-950 text-neutral-50 font-geist antialiased selection:bg-white/20 lg:overflow-hidden"
  >
    <div class="min-h-screen lg:h-screen">
      <div class="lg:grid lg:h-screen lg:grid-cols-2">
        <aside class="border-b border-white/8 px-6 py-8 lg:flex lg:min-h-screen lg:flex-col lg:justify-between lg:border-b-0 lg:border-r lg:px-10 lg:py-10">
          <div>
            <section class="animate-fade-in pt-8 lg:flex lg:min-h-[calc(100vh-14rem)] lg:flex-col lg:justify-center lg:pt-0">
              <h1 class="mt-4 text-5xl font-bold tracking-tight leading-none md:text-7xl">
                Mizan Ali<span class="inline-block w-[3px] h-[0.85em] bg-neutral-50 ml-1 align-middle animate-blink"></span>
              </h1>
              <p
                class="mt-6 max-w-xl text-base leading-relaxed text-neutral-400 font-light md:text-lg"
              >
                I am a fullstack product engineer, with a strong frontend focus.
                Over the last 4 years, I have worked at the intersection of
                complex frontend engineering and onchain realtime systems, most
                recently as a Lead Product Engineer at Huddle01. I love building
                consumer-facing apps in the web3 space.
              </p>
              <p class="mt-3 text-sm text-neutral-500 font-light">
                Abu Dhabi, UAE
              </p>
              <div class="mt-8 flex flex-wrap items-center gap-3">
                <a
                  href="/resume.pdf"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="border border-white/10 px-5 py-2.5 text-sm font-medium text-neutral-300 transition-all duration-300 hover:border-white/20 hover:text-neutral-50"
                  >Resume</a
                >
              </div>
            </section>
          </div>

          <div class="mt-10 border-t border-white/8 pt-6 lg:mt-8">
            <div class="mt-4 flex flex-wrap gap-4">
              {
                [
                  {
                    label: "Twitter",
                    url: "https://twitter.com/mizanxali",
                  },
                  {
                    label: "GitHub",
                    url: "https://github.com/mizanxali",
                  },
                  {
                    label: "LinkedIn",
                    url: "https://linkedin.com/in/mizanxali",
                  },
                  {
                    label: "Telegram",
                    url: "https://t.me/mizanxali",
                  },
                ].map((link) => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-neutral-400 transition-colors duration-300 hover:text-white"
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
          </div>
        </aside>

        <main
          id="content-pane"
          class="px-6 py-8 lg:h-screen lg:overflow-y-auto lg:px-10 lg:py-10"
        >
          <section id="work" class="scroll-mt-24">
            <div class="max-w-4xl">
              <div class="scroll-animate">
                <div>
                  <h3 class="text-2xl font-semibold tracking-tight md:text-3xl">
                    Things shipped at Huddle01
                  </h3>
                  <p class="mt-2 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
                    Lead Product Engineer, Jan 2023 - Mar 2026. Built core products across web3 and webRTC tech stacks using TypeScript.
                  </p>
                </div>

                <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
                  {
                    huddle01Projects.map((project, i) => (
                      <article
                        class="group scroll-animate overflow-hidden border border-white/8 bg-neutral-950/80 transition-all duration-500 hover:border-white/16 hover:bg-neutral-900/80"
                        style={`transition-delay: ${i * 50}ms`}
                      >
                        <div class="relative aspect-[16/9] overflow-hidden border-b border-white/8 bg-neutral-900">
                          {project.image ? (
                            <img
                              src={project.image}
                              alt={project.name}
                              loading="lazy"
                              class="absolute inset-0 h-full w-full object-cover object-top opacity-80 transition-all duration-500 group-hover:scale-[1.03] group-hover:opacity-100"
                            />
                          ) : (
                            <div class="absolute inset-0 flex items-center justify-center bg-[linear-gradient(135deg,#101010_0%,#171717_50%,#0a0a0a_100%)]">
                              <div class="flex items-center gap-4">
                                <div class="border border-white/12 p-3">
                                  <svg
                                    class="h-7 w-7 text-neutral-200"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    aria-hidden="true"
                                  >
                                    <rect x="4.5" y="4.5" width="15" height="15"></rect>
                                    <path d="M8 9.5h8"></path>
                                    <path d="M8 13h8"></path>
                                    <path d="M8 16.5h4.5"></path>
                                  </svg>
                                </div>
                                <div class="border border-white/12 p-3">
                                  <svg
                                    class="h-7 w-7 text-neutral-400"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    aria-hidden="true"
                                  >
                                    <path d="M6 7.5h12"></path>
                                    <path d="M6 12h12"></path>
                                    <path d="M6 16.5h7"></path>
                                  </svg>
                                </div>
                              </div>
                            </div>
                          )}
                        </div>
                        <div class="p-5">
                          <div class="flex items-center justify-between gap-4">
                            <h4 class="text-base font-semibold text-neutral-100 transition-colors group-hover:text-white">
                              {project.name}
                            </h4>
                            <svg
                              class="h-3.5 w-3.5 shrink-0 text-neutral-600 transition-colors group-hover:text-neutral-300"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M7 17L17 7M17 7H7M17 7v10"
                              />
                            </svg>
                          </div>
                          <p class="mt-2 text-sm leading-relaxed text-neutral-500 transition-colors group-hover:text-neutral-400">
                            {project.description}
                          </p>
                          <div class="mt-5 border-t border-white/8 pt-4">
                            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-600">
                              Links
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                              {
                                project.links.map((link) => (
                                  <a
                                    href={link.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 border border-white/10 px-3 py-1.5 text-[11px] font-medium text-neutral-300 transition-all duration-300 hover:border-white/20 hover:bg-white/4 hover:text-white"
                                  >
                                    <span>{link.label}</span>
                                    <svg
                                      class="h-3 w-3 text-neutral-500 transition-colors group-hover:text-neutral-300"
                                      fill="none"
                                      viewBox="0 0 24 24"
                                      stroke="currentColor"
                                      stroke-width="2"
                                    >
                                      <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M7 17L17 7M17 7H7M17 7v10"
                                      />
                                    </svg>
                                  </a>
                                ))
                              }
                            </div>
                          </div>
                          <div class="mt-4 border-t border-white/8 pt-4">
                            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-600">
                              Stack
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                              {
                                project.tech.map((tech) => {
                                  const meta = techMeta[tech] ?? null;
                                  return (
                                    <span class="inline-flex items-center gap-2 border border-white/10 px-3 py-1.5 text-[11px] font-medium text-neutral-300">
                                      {meta?.custom === "webrtc" ? (
                                        <svg
                                          class="h-3.5 w-3.5 text-neutral-300"
                                          viewBox="0 0 24 24"
                                          fill="none"
                                          stroke="currentColor"
                                          stroke-width="1.8"
                                          aria-hidden="true"
                                        >
                                          <circle cx="12" cy="12" r="2.25"></circle>
                                          <path d="M5.5 8.5a9 9 0 0 1 0 7"></path>
                                          <path d="M18.5 8.5a9 9 0 0 0 0 7"></path>
                                          <path d="M8.5 10.25a4.8 4.8 0 0 1 0 3.5"></path>
                                          <path d="M15.5 10.25a4.8 4.8 0 0 0 0 3.5"></path>
                                        </svg>
                                      ) : meta?.slug ? (
                                        <>
                                          <img
                                            src={meta.color
                                              ? `https://cdn.simpleicons.org/${meta.slug}/${meta.color}`
                                              : `https://cdn.simpleicons.org/${meta.slug}`}
                                            alt=""
                                            loading="lazy"
                                            class="h-3.5 w-3.5 opacity-90"
                                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                          />
                                          <span
                                            class="hidden h-3.5 w-3.5 items-center justify-center border border-white/20 text-[7px] uppercase leading-none text-neutral-400"
                                          >
                                            {meta.fallback ?? tech.slice(0, 2)}
                                          </span>
                                        </>
                                      ) : meta?.fallback ? (
                                        <span class="flex h-3.5 w-3.5 items-center justify-center border border-white/20 text-[7px] uppercase leading-none text-neutral-400">
                                          {meta.fallback}
                                        </span>
                                      ) : (
                                        <span class="flex h-3.5 w-3.5 items-center justify-center border border-white/20 text-[8px] uppercase text-neutral-400">
                                          {tech.slice(0, 1)}
                                        </span>
                                      )}
                                      <span>{tech}</span>
                                    </span>
                                  );
                                })
                              }
                            </div>
                          </div>
                        </div>
                      </article>
                    ))
                  }
                </div>
              </div>

              <section class="mt-16">
                <div class="scroll-animate">
                  <h3 class="text-2xl font-semibold tracking-tight md:text-3xl">
                    Side Projects
                  </h3>
                  <p class="mt-2 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
                    Experiments across AI, developer tooling, prediction markets, desktop software, and games.
                  </p>
                </div>

                <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
                  {
                    personalProjects.map((project, i) => (
                      <article
                        class="group scroll-animate overflow-hidden border border-white/8 bg-neutral-950/80 transition-all duration-500 hover:border-white/16 hover:bg-neutral-900/80"
                        style={`transition-delay: ${i * 50}ms`}
                      >
                        <div class="relative aspect-[16/9] overflow-hidden border-b border-white/8 bg-neutral-900">
                          {project.image ? (
                            <img
                              src={project.image}
                              alt={project.name}
                              loading="lazy"
                              class="absolute inset-0 h-full w-full object-cover object-top opacity-80 transition-all duration-500 group-hover:scale-[1.03] group-hover:opacity-100"
                            />
                          ) : (
                            <div class="absolute inset-0 flex items-center justify-center bg-[linear-gradient(135deg,#101010_0%,#171717_50%,#0a0a0a_100%)]">
                              <div class="flex items-center gap-4">
                                <div class="border border-white/12 p-3">
                                  <svg
                                    class="h-7 w-7 text-neutral-200"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    aria-hidden="true"
                                  >
                                    <rect x="4.5" y="4.5" width="15" height="15"></rect>
                                    <path d="M8 9.5h8"></path>
                                    <path d="M8 13h8"></path>
                                    <path d="M8 16.5h4.5"></path>
                                  </svg>
                                </div>
                                <div class="border border-white/12 p-3">
                                  <svg
                                    class="h-7 w-7 text-neutral-400"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    aria-hidden="true"
                                  >
                                    <path d="M6 7.5h12"></path>
                                    <path d="M6 12h12"></path>
                                    <path d="M6 16.5h7"></path>
                                  </svg>
                                </div>
                              </div>
                            </div>
                          )}
                        </div>
                        <div class="p-5">
                          <div class="flex items-center justify-between gap-4">
                            <h4 class="text-base font-semibold text-neutral-100 transition-colors group-hover:text-white">
                              {project.name}
                            </h4>
                            <svg
                              class="h-3.5 w-3.5 shrink-0 text-neutral-600 transition-colors group-hover:text-neutral-300"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M7 17L17 7M17 7H7M17 7v10"
                              />
                            </svg>
                          </div>
                          <p class="mt-2 text-sm leading-relaxed text-neutral-500 transition-colors group-hover:text-neutral-400">
                            {project.description}
                          </p>
                          <div class="mt-5 border-t border-white/8 pt-4">
                            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-600">
                              Links
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                              {
                                project.links.map((link) => (
                                  <a
                                    href={link.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="inline-flex items-center gap-2 border border-white/10 px-3 py-1.5 text-[11px] font-medium text-neutral-300 transition-all duration-300 hover:border-white/20 hover:bg-white/4 hover:text-white"
                                  >
                                    <span>{link.label}</span>
                                    <svg
                                      class="h-3 w-3 text-neutral-500 transition-colors group-hover:text-neutral-300"
                                      fill="none"
                                      viewBox="0 0 24 24"
                                      stroke="currentColor"
                                      stroke-width="2"
                                    >
                                      <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M7 17L17 7M17 7H7M17 7v10"
                                      />
                                    </svg>
                                  </a>
                                ))
                              }
                            </div>
                          </div>
                          <div class="mt-4 border-t border-white/8 pt-4">
                            <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-600">
                              Stack
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                              {
                                project.tech.map((tech) => {
                                  const meta = techMeta[tech] ?? null;
                                  return (
                                    <span class="inline-flex items-center gap-2 border border-white/10 px-3 py-1.5 text-[11px] font-medium text-neutral-300">
                                      {meta?.custom === "webrtc" ? (
                                        <svg
                                          class="h-3.5 w-3.5 text-neutral-300"
                                          viewBox="0 0 24 24"
                                          fill="none"
                                          stroke="currentColor"
                                          stroke-width="1.8"
                                          aria-hidden="true"
                                        >
                                          <circle cx="12" cy="12" r="2.25"></circle>
                                          <path d="M5.5 8.5a9 9 0 0 1 0 7"></path>
                                          <path d="M18.5 8.5a9 9 0 0 0 0 7"></path>
                                          <path d="M8.5 10.25a4.8 4.8 0 0 1 0 3.5"></path>
                                          <path d="M15.5 10.25a4.8 4.8 0 0 0 0 3.5"></path>
                                        </svg>
                                      ) : meta?.slug ? (
                                        <>
                                          <img
                                            src={meta.color
                                              ? `https://cdn.simpleicons.org/${meta.slug}/${meta.color}`
                                              : `https://cdn.simpleicons.org/${meta.slug}`}
                                            alt=""
                                            loading="lazy"
                                            class="h-3.5 w-3.5 opacity-90"
                                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                          />
                                          <span
                                            class="hidden h-3.5 w-3.5 items-center justify-center border border-white/20 text-[7px] uppercase leading-none text-neutral-400"
                                          >
                                            {meta.fallback ?? tech.slice(0, 2)}
                                          </span>
                                        </>
                                      ) : meta?.fallback ? (
                                        <span class="flex h-3.5 w-3.5 items-center justify-center border border-white/20 text-[7px] uppercase leading-none text-neutral-400">
                                          {meta.fallback}
                                        </span>
                                      ) : (
                                        <span class="flex h-3.5 w-3.5 items-center justify-center border border-white/20 text-[8px] uppercase text-neutral-400">
                                          {tech.slice(0, 1)}
                                        </span>
                                      )}
                                      <span>{tech}</span>
                                    </span>
                                  );
                                })
                              }
                            </div>
                          </div>
                        </div>
                      </article>
                    ))
                  }
                </div>

                <p class="mt-5 text-sm font-light text-neutral-500 scroll-animate">
                  + more on <a
                    href="https://github.com/mizanxali"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-neutral-300 underline decoration-neutral-700 underline-offset-4 transition-all duration-300 hover:text-white hover:decoration-neutral-400"
                    >GitHub</a
                  >
                </p>
              </section>

              <section class="mt-16">
                <div class="scroll-animate">
                  <h3 class="text-2xl font-semibold tracking-tight md:text-3xl">
                    Talks & Videos
                  </h3>
                  <p class="mt-2 max-w-2xl text-sm font-light leading-relaxed text-neutral-400">
                    Workshops, walkthroughs, and product-focused video content.
                  </p>
                </div>

                <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-2">
                  {
                    videos.map((video, i) => (
                      <div
                        class="scroll-animate overflow-hidden border border-white/8 bg-neutral-950/80"
                        style={`transition-delay: ${i * 50}ms`}
                      >
                        <div class="aspect-video border-b border-white/8">
                          {video.placeholder === "playlist" ? (
                            <a
                              href={video.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex h-full w-full items-center justify-center bg-[linear-gradient(135deg,#111111_0%,#171717_45%,#0a0a0a_100%)] px-8 text-center transition-colors duration-300 hover:bg-neutral-900"
                            >
                              <div class="flex flex-col items-center">
                                <div class="border border-white/12 p-5">
                                  <svg
                                    class="h-10 w-10 text-neutral-200"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.6"
                                    aria-hidden="true"
                                  >
                                    <rect x="4.5" y="5.5" width="15" height="3.5"></rect>
                                    <rect x="4.5" y="10.25" width="15" height="3.5"></rect>
                                    <rect x="4.5" y="15" width="15" height="3.5"></rect>
                                    <path d="M10 7.25 13 9v-3.5L10 7.25Z" fill="currentColor" stroke="none"></path>
                                    <path d="M10 12 13 13.75v-3.5L10 12Z" fill="currentColor" stroke="none"></path>
                                    <path d="M10 16.75 13 18.5V15L10 16.75Z" fill="currentColor" stroke="none"></path>
                                  </svg>
                                </div>
                                <p class="mt-5 text-[10px] font-semibold uppercase tracking-[0.24em] text-neutral-500">
                                  Playlist
                                </p>
                                <p class="mt-2 text-sm text-neutral-300">
                                  Open the full Huddle01 video library
                                </p>
                              </div>
                            </a>
                          ) : (
                            <iframe
                              src={video.embedUrl}
                              title={video.name}
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                              allowfullscreen
                              loading="lazy"
                              class="h-full w-full"
                            />
                          )}
                        </div>
                        <div class="p-5">
                          <h4 class="text-base font-semibold text-neutral-100">
                            {video.name}
                          </h4>
                          <p class="mt-2 text-sm leading-relaxed text-neutral-500">
                            {video.description}
                          </p>
                        </div>
                      </div>
                    ))
                  }
                </div>
              </section>
            </div>
          </section>
        </main>
      </div>
    </div>

    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 3.5rem;
        background: #0a0a0a;
      }

      body {
        min-height: 100vh;
      }

      @media (min-width: 1024px) {
        html,
        body {
          height: 100%;
        }
      }

      @keyframes blink {
        0%,
        50% {
          opacity: 1;
        }
        51%,
        100% {
          opacity: 0;
        }
      }

      .animate-blink {
        animation: blink 1s step-end infinite;
      }

      @keyframes fade-in {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .animate-fade-in {
        animation: fade-in 0.8s ease-out;
      }

      .scroll-animate {
        opacity: 0;
        transform: translateY(20px);
        transition:
          opacity 0.6s ease-out,
          transform 0.6s ease-out;
      }

      .scroll-animate.visible {
        opacity: 1;
        transform: translateY(0);
      }

      #content-pane {
        scrollbar-width: thin;
        scrollbar-color: rgba(250, 250, 250, 0.14) transparent;
      }

      #content-pane::-webkit-scrollbar {
        width: 10px;
      }

      #content-pane::-webkit-scrollbar-track {
        background: transparent;
      }

      #content-pane::-webkit-scrollbar-thumb {
        border: 3px solid transparent;
        background: rgba(250, 250, 250, 0.14);
        background-clip: content-box;
      }
    </style>

    <script>
      const contentPane = document.querySelector("#content-pane");
      const animatedElements = document.querySelectorAll(".scroll-animate");
      const isDesktop = () => window.matchMedia("(min-width: 1024px)").matches;

      const createObserver = () =>
        new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
              }
            });
          },
          {
            threshold: 0.12,
            root: isDesktop() ? contentPane : null,
            rootMargin: "0px 0px -80px 0px",
          }
        );

      let observer = createObserver();

      const observeAnimatedElements = () => {
        observer.disconnect();
        observer = createObserver();
        animatedElements.forEach((el) => {
          observer.observe(el);
        });
      };

      observeAnimatedElements();

      window.addEventListener("resize", observeAnimatedElements);

      document.querySelectorAll("[data-pane-link]").forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href");
          if (!href?.startsWith("#")) return;
          const target = document.querySelector(href);
          if (!target) return;
          if (isDesktop() && contentPane) {
            event.preventDefault();
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });
    </script>
  </body>
</html>
